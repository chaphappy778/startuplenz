NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# Comma-separated list of admin emails. Anyone whose Supabase Auth email
# matches an entry here can access /admin/*. Server-only (no NEXT_PUBLIC_
# prefix) so the list never leaks to the browser.
STARTUPLENZ_ADMIN_EMAILS=you@example.com

# Resend (email sending). Used by the "Email me my plan" capture flow.
# Get the key from https://resend.com/api-keys.
RESEND_API_KEY=re_your_key_here

# Sender address — must be on a Resend-verified domain.
# Recipients see the display name ("StartupLenz") most prominently, the @
# address less so. So "StartupLenz <hello@chaphaus.com>" reads as StartupLenz
# in their inbox list.
RESEND_FROM_ADDRESS="StartupLenz <hello@chaphaus.com>"

# Reply-To — where replies route. Set this to your StartupLenz inbox alias
# once you've configured email forwarding at the registrar (e.g.
# hello@startuplenz.com that forwards into your chaphaus mailbox).
# Optional — if unset, replies go to RESEND_FROM_ADDRESS.
RESEND_REPLY_TO=hello@startuplenz.com

# Resend webhook signing secret (from resend.com/webhooks). Used to verify
# incoming events on /api/webhooks/resend before recording them. In dev with
# no secret set, the route accepts all requests so you can test with curl.
RESEND_WEBHOOK_SECRET=whsec_your_secret_here

# Secret used to HMAC-sign unsubscribe links so users can't enumerate other
# subscribers' tokens. Can be any random string; rotating it invalidates all
# outstanding unsub links. If unset, falls back to SUPABASE_SERVICE_ROLE_KEY.
UNSUBSCRIBE_SECRET=any_long_random_string

# Google Analytics 4 measurement ID. Format: G-XXXXXXXXXX.
# Get this from analytics.google.com → Admin (gear icon, bottom left)
#   → Data Streams → Web → click the stream for startuplenz.com
#   → "Measurement ID" at the top right.
# Leave blank to disable tracking entirely (the GoogleAnalytics component
# renders nothing in that case, so local dev with no env var is fine).
NEXT_PUBLIC_GA_ID=
